{
  "name": "@peerfolio/privy-near-connect",
  "version": "0.0.0",
  "description": "Privy wallet adapter for near-connect",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./executor": {
      "types": "./dist/executor.d.ts",
      "default": "./dist/executor.js"
    },
    "./sign-page": {
      "types": "./dist/sign-page.d.ts",
      "default": "./dist/sign-page.js"
    }
  },
  "main": "./dist/executor.js",
  "types": "./dist/executor.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "happy-dom": "^20.8.4",
    "prettier": "^3.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@hot-labs/near-connect": "^0.11.1",
    "@near-js/crypto": "^2.5.1",
    "@near-js/types": "^2.5.1",
    "@noble/hashes": "^1.8.0",
    "@privy-io/js-sdk-core": "^0.60.5",
    "@scure/base": "^2.0.0",
    "borsh": "^2.0.0"
  }
}
